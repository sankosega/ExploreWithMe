    {
      "name": "Comments - Success Scenarios",
      "item": [
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Great event! Looking forward to attending.\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/comments?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "comments"],
              "query": [{"key": "eventId", "value": "{{eventId}}"}]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create comment - status 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Comment has id and text', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "    pm.expect(json.text).to.equal('Great event! Looking forward to attending.');",
                  "    pm.expect(json.createdOn).to.exist;",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('commentId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
