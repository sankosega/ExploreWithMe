              "raw": "{\"title\": \"Pending Event\", \"annotation\": \"Pending event annotation text here\", \"description\": \"Pending event description text here\", \"category\": {{categoryId}}, \"eventDate\": \"{{futureDate}}\", \"location\": {\"lat\": 55.76, \"lon\": 37.63}, \"paid\": false, \"participantLimit\": 0, \"requestModeration\": false}"
            },
