        {
          "name": "Create Event (Published)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var d = new Date();",
                  "d.setFullYear(d.getFullYear() + 1);",
                  "var pad = n => String(n).padStart(2,'0');",
                  "var ds = d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+' '+pad(d.getHours())+':'+pad(d.getMinutes())+':'+pad(d.getSeconds());",
                  "pm.collectionVariables.set('futureDate', ds);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create event - status 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('eventId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Test Event\", \"annotation\": \"Test event annotation text here\", \"description\": \"Test event description text here\", \"category\": {{categoryId}}, \"eventDate\": \"{{futureDate}}\", \"location\": {\"lat\": 55.75, \"lon\": 37.62}, \"paid\": false, \"participantLimit\": 0, \"requestModeration\": false}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "events"]
            }
          }
        },
        {
          "name": "Publish Event",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"stateAction\": \"PUBLISH_EVENT\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "events", "{{eventId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Publish event - status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Event state is PUBLISHED', function() {",
                  "    pm.expect(pm.response.json().state).to.equal('PUBLISHED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Event (Pending - not published)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var d = new Date();",
